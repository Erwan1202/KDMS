---
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";

const {
    title,
    description = "KDMS - Fabricant français de flight cases 100% sur mesure. Conception, fabrication et livraison personnalisées.",
    ogImage,
} = Astro.props;

const ogImageURL = ogImage
    ? new URL(ogImage, Astro.site ?? Astro.url.origin).href
    : undefined;

const isProd = import.meta.env.PROD;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

const jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "KDMS",
    "description": "Fabricant de flight cases sur mesure. Conception et fabrication personnalisées avec un suivi client dédié, entre artisanat et production industrielle.",
    "url": "https://www.k-dms.co",
    "logo": "https://www.k-dms.co/logo.png",
    "telephone": "+33169127210",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "8 Rue Camille Decauville",
        "addressLocality": "Tigery",
        "postalCode": "91250",
        "addressCountry": "FR"
    },
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.6365,
        "longitude": 2.5125
    },
    "sameAs": [],
    "knowsAbout": [
        "flight case",
        "conception flight case",
        "aménagement flight case",
        "flight case haute protection",
        "flight case technique",
        "flight case sur mesure",
        "flight case custom",
        "flight case personnalisé",
        "fabrication flight case",
        "fabricant flight case",
        "flight case professionnel",
        "flight case événementiel",
        "flight case industriel",
        "flight case spectacle",
        "flight case audiovisuel",
        "flight case médical",
        "flight case militaire",
        "flight case tournée",
        "flight case transport",
        "flight case protection matériel",
        "flight case mousse",
        "flight case capitonné",
        "flight case rack",
        "flight case à roulettes",
        "flight case empilable",
        "flight case étanche",
        "flight case robuste",
        "flight case aluminium",
        "flight case bois",
        "flight case grande dimension",
        "flight case série",
        "flight case prototype",
        "flight case France",
        "flight case Île-de-France",
        "flight case Essonne",
        "flight case Paris",
        "malette de transport sur mesure",
        "caisse de transport professionnelle",
        "valise technique sur mesure",
        "conditionnement sur mesure",
        "protection équipement",
        "emballage professionnel",
        "usinage CNC flight case",
        "menuiserie flight case",
        "agencement flight case",
        "valise résine",
        "valise résine sur mesure",
        "pelicase",
        "peli case",
        "pelican case",
        "valise étanche",
        "valise de protection",
        "valise technique résine"
    ]
});
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="robots" content="noimageindex" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content="fr_FR" />
        <meta property="og:site_name" content="KDMS" />
        {ogImageURL && <meta property="og:image" content={ogImageURL} />}

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

        <link rel="canonical" href={canonicalURL.href} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="192x192" href="/logo.png" />
        <link rel="apple-touch-icon" href="/logo.png" />

        <script type="application/ld+json" set:html={jsonLd} />
        <link rel="dns-prefetch" href="https://maps.google.com" />
        <link rel="dns-prefetch" href="https://maps.gstatic.com" />
        <link rel="preconnect" href="https://maps.google.com" />
        <link rel="preconnect" href="https://maps.gstatic.com" crossorigin />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <link
            rel="preload"
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@700&display=swap"
            as="style"
        />

        <title>{title}</title>
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            html,
            body {
                margin: 0;
                width: 100%;
                height: 100%;
            }
            html {
                scrollbar-width: none;
            }
            html::-webkit-scrollbar {
                display: none;
            }
            
            img {
                -webkit-user-select: none;
                -moz-user-select: none;
                -ms-user-select: none;
                user-select: none;
                pointer-events: none;
                -webkit-touch-callout: none;
            }
            
            .img-protect {
                position: relative;
            }
            
            .img-protect::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: transparent;
                pointer-events: auto;
            }
        </style>
    </head>
    <body class="bg-white scrollbar-hide overflow-x-hidden">
        <slot />
        {isProd && <SpeedInsights />}
        
        <script is:inline>
            document.addEventListener('contextmenu', function(e) {
                if (e.target.tagName === 'IMG' || e.target.closest('.img-protect')) {
                    e.preventDefault();
                    return false;
                }
            });
            
            document.addEventListener('dragstart', function(e) {
                if (e.target.tagName === 'IMG') {
                    e.preventDefault();
                    return false;
                }
            });
            
            document.addEventListener('keydown', function(e) {
                if (e.target.tagName === 'IMG') {
                    if ((e.ctrlKey || e.metaKey) && (e.key === 's' || e.key === 'S')) {
                        e.preventDefault();
                        return false;
                    }
                }
            });
        </script>
    </body>
</html>
