---
import { Image } from "astro:assets";
import logoWhite from "/src/assets/common/logo-white.png";
import madeInFrance from "/src/assets/common/Made-In-France.jpeg";
import ProtectedEmail from "./ProtectedEmail.astro";

const navigationLinks = [
    { label: "Accueil", href: "/" },
    { label: "Notre expertise", href: "/expertise" },
    { label: "Nos réalisations", href: "/#realisations" },
    { label: "Contact", href: "/contact" },
];



const legalLinks = [
    { label: "Mentions Légales", href: "/mentions-legales" },
    { label: "Politique de confidentialité", href: "/rgpd" },
    { label: "Plan du site", href: "/plan-du-site" },
];
---

<footer class="bg-[#161616] text-white py-8 md:py-10 relative overflow-hidden">
    <div class="relative max-w-7xl mx-auto px-6 md:px-8 z-10">
        <div class="flex flex-col lg:flex-row gap-8 lg:gap-0">
            <div class="w-full lg:w-[35%] flex flex-col gap-5 lg:border-r border-[rgba(255,255,255,0.08)] lg:pr-8 xl:pr-12 shrink-0">
                <div class="flex items-center justify-between w-full max-w-sm">
                    <a href="/" class="inline-block shrink-0">
                        <Image
                            src={logoWhite}
                            alt="KDMS"
                            height={72}
                            loading="lazy"
                            class="h-[54px] sm:h-[64px] w-auto transition-transform hover:scale-105"
                        />
                    </a>
                    <Image
                        src={madeInFrance}
                        alt="Made in France"
                        height={72}
                        loading="lazy"
                        class="w-auto h-[38px] sm:h-[46px] object-contain rounded-sm"
                    />
                </div>
                <p
                    class="text-[#B3B3B3] font-light leading-relaxed max-w-sm text-base mt-2 text-justify"
                >
                    Experts dans la conception et fabrication de flight cases
                    sur mesure. Protection optimale pour votre matériel, adaptée
                    à vos besoins spécifiques.
                </p>
            </div>

            {/* Colonnes de droite : Liens regroupés */}
            <div class="w-full lg:w-[65%] flex flex-col sm:flex-row gap-10 sm:gap-6 lg:gap-14 xl:gap-24 lg:pl-10 xl:pl-16 mt-4 lg:mt-0 justify-start">
                <div class="flex-1 lg:flex-none whitespace-nowrap">
                    <h3 class="footer-title">Navigation</h3>
                    <div class="flex flex-col gap-2">
                        {
                            navigationLinks.map((link) => (
                                <a href={link.href} class="footer-link">
                                    {link.label}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <div class="flex-[1.2] lg:flex-none">
                    <h3 class="footer-title">Contact</h3>
                    <div class="flex flex-col gap-4">
                        <a
                            href="https://www.google.com/maps/search/?api=1&query=8+Rue+Camille+Décauville+91250+Tigery+France"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="footer-link block leading-relaxed"
                        >
                            8 Rue Camille Décauville<br />
                            91250 Tigery<br />
                            France
                        </a>
                        
                        <div class="flex flex-col leading-relaxed justify-between">
                            <a href="tel:+33169127210" class="footer-link">01 69 12 72 10</a>
                            <ProtectedEmail linkClass="text-[#b8b8b8] hover:text-[#4A5D23] font-light font-[300] transition-colors duration-200" />
                            <a href="https://www.linkedin.com/in/regis-kozak-a714337/" target="_blank" rel="noopener noreferrer" class="footer-link flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#4A5D23]">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle>
                                </svg>
                                LinkedIn
                            </a>
                        </div>
                    </div>
                </div>

                <div class="flex-1 lg:flex-none whitespace-nowrap">
                    <h3 class="footer-title">Infos</h3>
                    <div class="flex flex-col gap-2">
                        {
                            legalLinks.map((link) => (
                                <a href={link.href} class="footer-link">
                                    {link.label}
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom mt-8 pt-5 text-center">
            <p>
                &copy; {new Date().getFullYear()} KDMS. Tous droits réservés.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer-title {
        color: #4A5D23;
        font-size: 1.125rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    .footer-link {
        color: #b8b8b8;
        font-weight: 300;
        transition: color 0.2s ease;
        text-decoration: none;
        width: fit-content;
    }

    .footer-link:hover {
        color: #4A5D23;
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        color: #a3a3a3;
        font-size: 0.875rem;
        font-weight: 300;
    }
</style>

