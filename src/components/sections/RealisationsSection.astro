---
import { categories } from "../../data/realisations";

interface Props {
  coverImages: Record<string, string>;
}

const { coverImages } = Astro.props;

const featuredCategories = categories
  .filter(cat => cat.featured)
  .map(cat => ({
    title: cat.label,
    category: cat.id,
    gridClass: cat.gridClass || "md:col-span-1",
    imageUrl: coverImages[cat.id] ?? null,
  }));
---

<section
    id="realisations"
    class="realisations-section w-full py-12 md:py-20 px-0 md:px-8 bg-[#0E0E0E]"
>
    <div class="w-full max-w-5xl mx-auto text-center mb-8 md:mb-12 px-6 md:px-8">
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-bold mb-3 md:mb-4 mt-6 md:mt-8 tracking-tight text-white">
            Nos <span class="text-[#4A5D23]">réalisations</span>
        </h2>
        <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-[#B8B8B8] font-medium">
            Découvrez la diversité de nos projets pour différents secteurs
        </p>
    </div>

    <!-- Ancienne présentation 5 colonnes mais avec un texte plus petit proportionnellement -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 w-full px-4 md:px-8 auto-rows-min">
        {
            featuredCategories.map((item) => (
                <a
                    href={`/realisations?category=${item.category}`}
                    class={`realisation-card group relative w-full h-[300px] overflow-hidden rounded-2xl bg-[#1A1A1A] cursor-pointer block no-underline transition-all duration-700 hover:shadow-[0_20px_40px_rgba(0,0,0,0.6)] ${item.gridClass}`}
                    data-category={item.category}
                >
                    {item.imageUrl ? (
                        <img
                            src={item.imageUrl}
                            alt={item.title}
                            loading="lazy"
                            decoding="async"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-70 group-hover:opacity-100 transition-all filter brightness-[0.8] group-hover:brightness-100"
                        />
                    ) : (
                        <div class="absolute inset-0 w-full h-full bg-gray-900/50 flex items-center justify-center">
                            <span class="text-white/20 font-bold uppercase tracking-widest text-xs">En cours...</span>
                        </div>
                    )}

                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-hover:opacity-40 transition-opacity duration-700" />

                    <div class="absolute bottom-0 left-0 w-full p-4 sm:p-5 pointer-events-none">
                        <span class="text-[#E07A1F] text-[10px] font-bold uppercase tracking-[0.2em] mb-1 sm:mb-2 block transform translate-y-3 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100 italic">
                            Secteur {item.title}
                        </span>
                        <!-- Titre réduit pour éviter les débordements -->
                        <h3 class="text-xl sm:text-xl lg:text-2xl font-extrabold text-white tracking-tighter leading-tight transform transition-all duration-700 group-hover:-translate-y-1">
                            {item.title}
                        </h3>

                        <div class="h-[2px] w-8 sm:w-10 bg-white/40 mt-3 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-left"></div>
                    </div>

                    <div class="absolute inset-0 border border-white/5 rounded-2xl pointer-events-none transition-colors duration-500 group-hover:border-white/20" />
                </a>
            ))
        }
    </div>

    <div class="w-full flex justify-center mt-10 md:mt-16">
        <a
            href="/realisations"
            class="cta-button group relative inline-flex items-center justify-center px-8 sm:px-10 py-3 md:py-4 overflow-hidden rounded-full bg-[#E07A1F] transition-all duration-300 hover:bg-[#C86618] hover:shadow-[0_0_30px_rgba(224,122,31,0.4)] whitespace-nowrap no-underline"
        >
            <span class="relative flex items-center gap-3 text-white font-medium text-sm tracking-[0.15em] uppercase transition-colors">
                Toutes nos réalisations
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
            </span>
        </a>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const ctaButton = document.querySelector(".cta-button");

    if (ctaButton) {
        gsap.to(ctaButton, {
            scrollTrigger: {
                trigger: ctaButton,
                start: "top 90%",
                toggleActions: "play none none reverse",
            },
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "back.out(1.7)",
        });
    }

    // -- DYNAMIQUE FETCH POUR VERCEL (Staleness Bypass) --
    // Pour mettre à jour les images statiques générées lors de la build
    document.addEventListener("DOMContentLoaded", () => {
        fetch('/api/gallery.php')
            .then(res => res.json())
            .then(data => {
                if (data.ok && data.images) {
                    const cards = document.querySelectorAll('.realisation-card');
                    cards.forEach(card => {
                        const cat = card.getAttribute('data-category');
                        if (!cat) return;
                        
                        // Trouver la première (donc plus récente) image pour cette catégorie
                        const firstImage = data.images.find((img: any) => 
                            img.category && img.category.toLowerCase().replace(/ /g, '-') === cat
                        );
                        
                        if (firstImage && firstImage.secure_url) {
                            const imgEl = card.querySelector('img');
                            if (imgEl) {
                                // Ne remplacer que si l'URL est différente pour éviter un flicker inutile
                                if (imgEl.src !== firstImage.secure_url) {
                                    imgEl.src = firstImage.secure_url;
                                }
                            } else {
                                // Si pas d'image (En cours...), on l'injecte
                                card.innerHTML = card.innerHTML.replace(
                                    /<div class="absolute inset-0.*?<\/div>/, 
                                    `<img src="${firstImage.secure_url}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-70 group-hover:opacity-100 transition-all filter brightness-[0.8] group-hover:brightness-100" />`
                                );
                            }
                        }
                    });
                }
            })
            .catch(console.error);
    });
</script>
