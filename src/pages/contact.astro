---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import { Image } from "astro:assets";
import heroBanner from "../assets/contact/hero-banner.png";
import ProtectedEmail from "../components/common/ProtectedEmail.astro";
---

<Layout
    title="Contact KDMS — Devis gratuit flight case sur mesure Tigery"
    description="Contactez KDMS à Tigery (91) pour vos projets flight case. Devis gratuit, fabrication personnalisée, livraison France & international. Feedback rapide."
>
    <Navbar theme="dark" />

    <main class="bg-black text-white min-h-screen pt-24">
        <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mb-16 lg:mb-20">
            <div class="mb-10 animate-text opacity-0">
                <p class="text-[#E07A1F] uppercase tracking-[0.2em] text-xs sm:text-sm font-semibold mb-3">
                    Contact
                </p>
                <h1 class="text-3xl sm:text-5xl font-bold tracking-tight">
                    Organisons votre projet de flight case
                </h1>
            </div>

            <div class="grid xl:grid-cols-2 gap-8 lg:gap-10 items-start xl:items-stretch">
                <div class="flex flex-col gap-8 xl:min-h-225 xl:h-full">
                    <article class="animate-info rounded-2xl border border-white/15 bg-white/10 backdrop-blur-md p-6 md:p-8 shadow-[0_12px_40px_rgba(0,0,0,0.35)]">
                        <h2 class="text-2xl md:text-3xl font-bold mb-6">Contactez-nous</h2>

                        <div class="flex items-center gap-3 pb-5 mb-5 border-b border-white/10 animate-fade-content opacity-0">
                            <div class="w-12 h-12 rounded-full bg-[#4A5D23] flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <div>
                                <span class="text-[#4A5D23] font-bold text-xs tracking-widest uppercase block">Votre interlocuteur</span>
                                <p class="text-lg font-semibold">Régis KOZAK</p>
                                <p class="text-white/60 text-sm">Direction</p>
                            </div>
                        </div>

                        <div class="space-y-5">
                            <div class="flex items-start gap-3 animate-fade-content opacity-0">
                                <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#4A5D23]"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                </div>
                                <div>
                                    <span class="text-white/50 text-[10px] uppercase tracking-wider block mb-0.5">Téléphone</span>
                                    <a href="tel:+33169127210" class="text-white font-medium text-sm hover:text-[#4A5D23] transition-colors">+33 1 69 12 72 10</a>
                                </div>
                            </div>

                            <div class="flex items-start gap-3 animate-fade-content opacity-0">
                                <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#4A5D23]"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                </div>
                                <div>
                                    <span class="text-white/50 text-[10px] uppercase tracking-wider block mb-0.5">Email</span>
                                    <ProtectedEmail linkClass="text-white font-medium text-sm hover:text-[#4A5D23] transition-colors" />
                                </div>
                            </div>

                            <div class="flex items-start gap-3 animate-fade-content opacity-0">
                                <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#4A5D23]"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                </div>
                                <div>
                                    <span class="text-white/50 text-[10px] uppercase tracking-wider block mb-0.5">Adresse</span>
                                    <p class="text-white font-medium text-sm">8 Rue Camille Décauville<br />91250 Tigery, France</p>
                                </div>
                            </div>

                            <div class="pt-4 border-t border-white/10 animate-fade-content opacity-0">
                                <a
                                    href="#callback-form"
                                    onclick="document.getElementById('callback').checked = true;"
                                    class="w-full group relative inline-flex items-center justify-center gap-2 px-4 py-3 overflow-hidden rounded-full bg-[#E07A1F] border border-[#E07A1F]/50 shadow-[0_4px_15px_rgba(224,122,31,0.2)] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_6px_20px_rgba(224,122,31,0.4)] hover:bg-[#C86618]"
                                >
                                    <span class="relative text-white font-bold text-sm tracking-wide">Être rappelé</span>
                                </a>
                            </div>
                        </div>
                    </article>

                    <article class="animate-map opacity-0 rounded-2xl border border-white/15 bg-[#111111] p-3 md:p-4 shadow-[0_12px_40px_rgba(0,0,0,0.35)] xl:mt-auto">
                        <div
                            class="w-full h-72 sm:h-80 md:h-95 rounded-xl overflow-hidden border border-white/10 shadow-lg bg-[#1a1a1a]"
                        >
                            <iframe
                                title="Localisation KDMS - 8 Rue Camille Décauville, 91250 Tigery"
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen
                                loading="eager"
                                referrerpolicy="no-referrer-when-downgrade"
                                src="https://www.google.com/maps/embed?origin=mfe&pb=!1m3!2m1!1s8+Rue+Camille+D%C3%A9cauville,+91250+Tigery!6i14"
                                class="w-full h-full"
                            ></iframe>
                        </div>
                    </article>
                </div>

                <div class="flex flex-col gap-8 xl:min-h-225 xl:h-full">
                    <article class="hidden xl:block animate-text opacity-0 rounded-2xl border border-white/15 overflow-hidden bg-[#0f0f0f] shadow-[0_12px_40px_rgba(0,0,0,0.35)]">
                        <div class="relative h-80 md:h-105">
                            <Image
                                src={heroBanner}
                                alt="Atelier K-DMS - Flight cases sur mesure"
                                class="w-full h-full object-cover"
                                loading="eager"
                                fetchpriority="high"
                                quality="max"
                            />                            
                        </div>
                    </article>

                    <article
                        id="callback-form"
                        class="animate-form opacity-0 rounded-2xl border border-white/20 bg-white/10 p-6 md:p-8 lg:p-10 shadow-[0_12px_40px_rgba(0,0,0,0.35)] scroll-mt-24 xl:mt-auto"
                    >
                        <h2 class="text-2xl md:text-3xl font-bold mb-2">Formulaire</h2>
                        <p class="text-white/40 text-xs mb-4">Les champs marqués d'un <span class="text-red-400">*</span> sont obligatoires</p>
                        <form id="contact-page-form" class="flex flex-col gap-6">
                            <input type="text" name="bot-field" class="hidden" tabindex="-1" autocomplete="off" />
                            <input type="hidden" name="source" value="Page Contact" />
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="relative group">
                                    <input type="text" id="firstname" name="firstname" class="peer w-full bg-transparent border-b border-white/20 py-2 text-white placeholder-transparent focus:border-[#4A5D23] focus:outline-none transition-colors" placeholder="Prénom" required />
                                    <label for="firstname" class="absolute left-0 -top-2.5 text-xs text-white/50 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/50 peer-placeholder-shown:top-2 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#4A5D23]">Prénom <span class="text-red-400">*</span></label>
                                </div>
                                <div class="relative group">
                                    <input type="text" id="lastname" name="lastname" class="peer w-full bg-transparent border-b border-white/20 py-2 text-white placeholder-transparent focus:border-[#4A5D23] focus:outline-none transition-colors" placeholder="Nom" required />
                                    <label for="lastname" class="absolute left-0 -top-2.5 text-xs text-white/50 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/50 peer-placeholder-shown:top-2 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#4A5D23]">Nom <span class="text-red-400">*</span></label>
                                </div>
                                <div class="relative group">
                                    <input type="email" id="email" name="email" class="peer w-full bg-transparent border-b border-white/20 py-2 text-white placeholder-transparent focus:border-[#4A5D23] focus:outline-none transition-colors" placeholder="Email" required />
                                    <label for="email" class="absolute left-0 -top-2.5 text-xs text-white/50 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/50 peer-placeholder-shown:top-2 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#4A5D23]">Email <span class="text-red-400">*</span></label>
                                </div>
                                <div class="relative group">
                                    <input type="tel" id="phone" name="phone" inputmode="tel" class="peer w-full bg-transparent border-b border-white/20 py-2 text-white placeholder-transparent focus:border-[#4A5D23] focus:outline-none transition-colors" placeholder="Téléphone" required />
                                    <label for="phone" class="absolute left-0 -top-2.5 text-xs text-white/50 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/50 peer-placeholder-shown:top-2 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#4A5D23]">Téléphone <span class="text-red-400">*</span></label>
                                </div>
                            </div>

                            <div class="relative group">
                                <textarea id="message" name="message" rows="4" class="peer w-full bg-transparent border-b border-white/20 py-2 text-white placeholder-transparent focus:border-[#4A5D23] focus:outline-none transition-colors resize-none" placeholder="Message"></textarea>
                                <label for="message" class="absolute left-0 -top-2.5 text-xs text-white/50 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-white/50 peer-placeholder-shown:top-2 peer-focus:-top-2.5 peer-focus:text-xs peer-focus:text-[#4A5D23]">Message</label>
                            </div>

                            <div class="flex items-center gap-3 py-2">
                                <label class="relative flex items-center cursor-pointer group">
                                    <input type="checkbox" id="callback" name="callback" class="peer sr-only" />
                                    <div class="w-5 h-5 border-2 border-white/30 rounded flex items-center justify-center transition-all duration-200 peer-checked:bg-[#E07A1F] peer-checked:border-[#E07A1F] group-hover:border-white/50">
                                        <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    </div>
                                    <span class="ml-3 text-white/80 text-sm font-medium group-hover:text-white transition-colors flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#E07A1F]"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                        Je souhaite être rappelé
                                    </span>
                                </label>
                            </div>

                            <button type="submit" class="mt-2 w-full group relative inline-flex items-center justify-center px-8 py-3 overflow-hidden rounded-full bg-[#4A5D23] border border-[#4A5D23] shadow-[0_6px_20px_rgba(74,93,35,0.3)] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_8px_30px_rgba(74,93,35,0.5)]">
                                <span class="relative text-white font-bold text-lg tracking-wider">Envoyer le message</span>
                            </button>
                        </form>
                    </article>
                </div>
            </div>
        </section>

        <script>
            import { gsap } from "gsap";

            const timeline = gsap.timeline({
                defaults: { ease: "power3.out" },
            });

            timeline.from(
                ".animate-info",
                {
                    y: 30,
                    duration: 0.8,
                    ease: "power3.out",
                },
                0.2,
            );

            timeline.fromTo(
                ".animate-fade-content",
                { y: 20, opacity: 0 },
                { y: 0, opacity: 1, duration: 0.6, stagger: 0.1 },
                0.4,
            );

            timeline
                .fromTo(
                    ".animate-text",
                    { y: 30, opacity: 0 },
                    { y: 0, opacity: 1, duration: 0.8, stagger: 0.1 },
                    0.4,
                )
                .fromTo(
                    ".animate-form",
                    { x: 30, opacity: 0 },
                    { x: 0, opacity: 1, duration: 0.8 },
                    0.6,
                )
                .fromTo(
                    ".animate-map",
                    { y: 30, opacity: 0 },
                    { y: 0, opacity: 1, duration: 0.8 },
                    0.8,
                );
        </script>

        <style> 
            input:-webkit-autofill,
            input:-webkit-autofill:hover,
            input:-webkit-autofill:focus,
            textarea:-webkit-autofill,
            textarea:-webkit-autofill:hover,
            textarea:-webkit-autofill:focus {
                -webkit-text-fill-color: white;
                -webkit-box-shadow: 0 0 0px 1000px #000 inset;
                transition: background-color 5000s ease-in-out 0s;
            }
        </style>

        <!-- SEO Content: Hidden for search engines -->
        <section class="hidden" role="region" aria-label="Contact keywords">
            <p>Contactez KDMS pour vos projets de flight case sur mesure. Fabrication personnalisée à Tigery (91), livraison France et international.</p>
        </section>
        
        <Footer />
        <script>
            const form = document.getElementById('contact-page-form') as HTMLFormElement;
            const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

            // Auto-formatage téléphone : 06 12 34 56 78
            const phoneInput = document.getElementById('phone') as HTMLInputElement;
            phoneInput?.addEventListener('input', () => {
                const raw = phoneInput.value.replace(/\D/g, '').slice(0, 10);
                phoneInput.value = raw.replace(/(\d{2})(?=\d)/g, '$1 ').trim();
            });
            
            form?.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Désactiver le bouton pendant l'envoi
                const originalText = submitBtn.textContent || 'Envoyer le message';
                submitBtn.disabled = true;
                
                // Modify button content while keeping the style span
                submitBtn.innerHTML = `
                    <span class="relative text-white font-bold text-lg tracking-wider">
                        Envoi en cours...
                    </span>
                `;
                
                try {
                    const formData = new FormData(form);
                    formData.append('form-time', Math.floor(Date.now() / 1000).toString());
                    
                    const response = await fetch('/send-email.php', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        // Afficher le message de succès
                        form.innerHTML = `
                            <div class="text-center py-8">
                                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-500/20 flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </div>
                                <p class="text-white text-lg font-semibold">Message envoyé !</p>
                                <p class="text-white/60 text-sm mt-2">Nous vous recontacterons rapidement.</p>
                            </div>
                        `;
                    } else {
                        throw new Error(result.message || "Erreur lors de l'envoi");
                    }
                } catch (error) {
                    // Afficher l'erreur
                    const errorDiv = document.createElement('div');
                    errorDiv.className = 'form-error-msg bg-red-500/20 border border-red-500/50 rounded-lg p-3 text-red-300 text-sm mb-4';
                    errorDiv.textContent = error instanceof Error ? error.message : "Erreur réseau lors de l'envoi. Veuillez réessayer.";
                    
                    // Supprimer l'ancienne erreur si présente
                    form.querySelector('.form-error-msg')?.remove();
                    form.insertBefore(errorDiv, form.firstChild);
                    
                    // Réactiver le bouton
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = `
                        <span class="relative text-white font-bold text-lg tracking-wider">
                            ${originalText.trim()}
                        </span>
                    `;
                }
            });
        </script>
    </main>
</Layout>
