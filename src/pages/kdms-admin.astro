---
const categories = [
  { id: 'evenementiel', label: 'Événementiel' },
  { id: 'meubles', label: 'Meubles' },
  { id: 'audiovisuel', label: 'Audiovisuel' },
  { id: 'valise-resine', label: 'Valise résine' },
  { id: 'industrie', label: 'Industrie' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — KDMS</title>
    <!-- Cropper.js CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js" is:inline></script>
    <style is:global>

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0e0e0e; color: #fff; font-family: system-ui, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; transition: opacity 0.2s;}
      .card { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 16px; padding: 36px 32px; width: 100%; max-width: 480px; }
      .card.wide { max-width: 960px; }
      .admin-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
      @media (max-width: 700px) { .admin-layout { grid-template-columns: 1fr; } }
      .section-title { color: #888; font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 14px; }
      .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 8px; max-height: 480px; overflow-y: auto; }
      .gallery-item { position: relative; border-radius: 8px; overflow: hidden; background: #111; aspect-ratio: 1; }
      .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .gallery-item-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0); display: flex; align-items: flex-end; transition: background 0.2s; }
      .gallery-item:hover .gallery-item-overlay { background: rgba(0,0,0,0.55); }
      .gallery-item-info { padding: 6px 8px; font-size: 0.68em; color: #fff; opacity: 0; transition: opacity 0.2s; line-height: 1.3; }
      .gallery-item:hover .gallery-item-info { opacity: 1; }
      .delete-btn { position: absolute; top: 6px; right: 6px; background: rgba(220,50,50,0.85); border: none; color: #fff; border-radius: 50%; width: 26px; height: 26px; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
      .gallery-item:hover .delete-btn { opacity: 1; }
      .delete-btn:hover { background: #dc2626; }
      .gallery-empty { color: #444; font-size: 0.85em; text-align: center; padding: 24px 0; }
      .logo { display: flex; flex-direction: column; align-items: center; gap: 6px; margin-bottom: 28px; }
      .logo-icon { width: 44px; height: 44px; background: #4A5D23; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
      .logo-title { font-weight: 700; font-size: 1.1em; letter-spacing: 0.12em; }
      .logo-sub { color: #555; font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.18em; }
      label { display: block; color: #888; font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 6px; }
      input[type="password"], input[type="text"] { width: 100%; background: #111; border: 1px solid #333; border-radius: 8px; padding: 10px 14px; color: #fff; font-size: 0.95em; outline: none; transition: border-color 0.2s; }
      input:focus { border-color: #4A5D23; }
      .btn { width: 100%; padding: 12px; border: none; border-radius: 8px; background: #E07A1F; color: #fff; font-weight: 700; font-size: 0.85em; letter-spacing: 0.12em; cursor: pointer; transition: background 0.2s; margin-top: 4px; }
      .btn:hover { background: #c86618; }
      .btn:disabled { background: #444; cursor: not-allowed; }
      .error-msg { background: rgba(220,50,50,0.1); border: 1px solid rgba(220,50,50,0.3); border-radius: 6px; padding: 8px 12px; color: #f87171; font-size: 0.82em; margin-top: 12px; display: none; }
      .warning-box { background: rgba(224,122,31,0.08); border: 1px solid rgba(224,122,31,0.2); border-radius: 6px; padding: 8px 12px; color: #e07a1f; font-size: 0.75em; margin-top: 14px; }
      .gap { display: flex; flex-direction: column; gap: 16px; }
      .status-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .connected { color: #7fb255; font-size: 0.82em; font-weight: 600; }
      .logout-btn { background: none; border: 1px solid #333; color: #888; border-radius: 20px; padding: 4px 12px; font-size: 0.75em; cursor: pointer; transition: all 0.2s; }
      .logout-btn:hover { border-color: #555; color: #ccc; }
      .drop-zone { border: 2px dashed #333; border-radius: 10px; padding: 32px; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
      .drop-zone:hover, .drop-zone.drag-over { border-color: #4A5D23; background: rgba(74,93,35,0.05); }
      .drop-icon { font-size: 28px; margin-bottom: 8px; }
      .drop-label { color: #ccc; font-size: 0.9em; font-weight: 500; }
      .drop-hint { color: #555; font-size: 0.75em; margin-top: 4px; }
      .preview-box { background: #111; border: 1px solid #2a2a2a; border-radius: 8px; padding: 10px; display: none; align-items: center; gap: 12px; }
      .preview-thumb { width: 56px; height: 56px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
      .preview-name { color: #ccc; font-size: 0.82em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .preview-ok { color: #7fb255; font-size: 0.75em; margin-left: auto; flex-shrink: 0; }
      .chips { display: flex; flex-wrap: wrap; gap: 8px; }
      .chip { background: #111; color: #888; border: 1px solid #333; padding: 5px 14px; border-radius: 20px; font-size: 0.8em; cursor: pointer; transition: all 0.15s; user-select: none; }
      .chip.selected { background: #4A5D23; color: #fff; border-color: #4A5D23; font-weight: 600; }
      .success-msg { background: rgba(74,93,35,0.15); border: 1px solid rgba(74,93,35,0.4); border-radius: 6px; padding: 10px 14px; color: #7fb255; font-size: 0.85em; display: none; text-align: center; }
      .ia-badge { position: absolute; top: 6px; left: 6px; background: rgba(74,93,35,0.9); color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.6em; font-weight: bold; letter-spacing: 0.05em; text-transform: uppercase; z-index: 5; pointer-events: none; }
      .cropper-container-wrapper { background: #111; border: 1px solid #2a2a2a; border-radius: 8px; padding: 10px; display: none; flex-direction: column; gap: 12px; }
      .cropper-image-wrapper { width: 100%; max-height: 400px; display: flex; justify-content: center; background: #000; overflow: hidden; border-radius: 4px; }
      .cropper-actions { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
      .cropper-btn { background: #333; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 0.8em; transition: 0.2s; }
      .cropper-btn:hover { background: #444; }

      [data-view="login"] { display: none; }
      [data-view="admin"] { display: none; }
      body.view-login [data-view="login"] { display: block; }
      body.view-admin [data-view="admin"] { display: block; }
    </style>
  </head>
  <body style="opacity: 0;" id="root">
    <div class="card" id="main-card">
      <div class="logo">
        <span class="logo-title">KDMS Admin</span>
        <span class="logo-sub">Espace réservé</span>
      </div>

      <!-- VIEW: LOGIN -->
      <div data-view="login">
        <form id="login-form" class="gap">
          <div>
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" autocomplete="current-password" required />
          </div>
          <button type="submit" class="btn">ACCÉDER</button>
          <div id="login-error" class="error-msg"></div>
        </form>
      </div>

      <!-- VIEW: ADMIN -->
      <div data-view="admin">
        <div class="status-bar">
          <span class="connected">● Connecté</span>
          <button class="logout-btn" id="logout-btn">Déconnexion</button>
        </div>

        <div class="admin-layout">
          <!-- Upload -->
          <div>
            <div class="section-title">Ajouter une photo</div>
            <form id="upload-form" class="gap">
              <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp" style="display:none" />
              <div class="drop-zone" id="drop-zone">
                <div class="drop-icon">📁</div>
                <div class="drop-label">Sélectionner ou glisser une photo</div>
                <div class="drop-hint">JPG, PNG, WebP</div>
              </div>

              <!-- Éditeur d'image (CropperJS) -->
              <div class="cropper-container-wrapper" id="editor-box">
                <div class="cropper-image-wrapper">
                  <img id="image-to-crop" style="max-width: 100%; display: block;" />
                </div>
                <div class="cropper-actions">
                  <button type="button" class="cropper-btn" id="btn-rotate-left">↺ 90°</button>
                  <button type="button" class="cropper-btn" id="btn-rotate-right">↻ 90°</button>
                  <button type="button" class="cropper-btn" id="btn-reset">Réinitialiser</button>
                  <button type="button" class="cropper-btn" style="background:#dc2626;" id="btn-cancel">Annuler</button>
                </div>
              </div>

              <div>
                <label for="title-input">Titre de la réalisation</label>
                <input type="text" id="title-input" name="title" placeholder="ex: Rack console son Yamaha" maxlength="120" required />
              </div>

              <div>
                <label>Options liées à la photo</label>
                <label style="display:flex; align-items:center; gap: 8px; cursor:pointer; color:#ccc; text-transform:none; font-size:0.85em; font-weight:500;">
                  <input type="checkbox" id="ia-input" style="width:auto; transform: scale(1.2);" />
                  Générée par Intelligence Artificielle (IA)
                </label>
              </div>

              <div>
                <label>Catégorie</label>
                <div class="chips" id="chips">
                  {categories.map(cat => (
                    <span class="chip" data-value={cat.id}>{cat.label}</span>
                  ))}
                </div>
                <input type="hidden" id="category-input" name="category" />
              </div>

              <div id="upload-error" class="error-msg"></div>
              <div id="upload-success" class="success-msg">✓ Photo publiée dans la galerie !</div>

              <button type="submit" class="btn" id="submit-btn" disabled>PUBLIER DANS LA GALERIE →</button>
            </form>
          </div>

          <!-- Galerie -->
          <div id="gallery-section">
            <div class="section-title">Galerie</div>
            <div id="gallery-container">Chargement...</div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      const root = document.getElementById('root');
      const card = document.getElementById('main-card');
      
      // GALLERY - Move before checkAuth() so it's defined when called
      const galleryContainer = document.getElementById('gallery-container');
      async function loadGallery() {
        try {
          galleryContainer.innerHTML = 'Chargement de la galerie...';
          const res = await fetch('/api/gallery.php');
          const text = await res.text();
          let data;
          try {
            data = JSON.parse(text);
          } catch (e) {
            console.error('Réponse API non-JSON (probablement du code PHP brut) :', text);
            if (text.startsWith('<?php') || text.includes('<?php')) {
               galleryContainer.innerHTML = '<div class="warning-box">Note: en développement local, les scripts PHP ne s\'exécutent pas (Vite ne gère pas PHP). Déployez ou utilisez un serveur PHP local.</div>';
               return;
            }
            throw new Error('API format invalide');
          }
          if (!data.images || data.images.length === 0) {
            galleryContainer.innerHTML = '<div class="gallery-empty">Aucune photo pour l\'instant.</div>';
            return;
          }
          const html = data.images.map(img => {
            const thumbUrl = img.secure_url.replace('/upload/', '/upload/c_fill,w_300,h_300/');
            const iaBadge = img.ia === 'true' ? '<div class="ia-badge">IA</div>' : '';
            return `
            <div class="gallery-item" data-public-id="${img.public_id}">
              ${iaBadge}
              <img src="${thumbUrl}" alt="${img.title}" loading="lazy" />
              <div class="gallery-item-overlay">
                <div class="gallery-item-info">${img.title} (${img.category})</div>
              </div>
              <button class="delete-btn" aria-label="Supprimer">✕</button>
            </div>
            `;
          }).join('');
          galleryContainer.innerHTML = `<div class="gallery-grid">${html}</div>`;
        } catch(e) {
          galleryContainer.innerHTML = '<div class="error-msg" style="display:block">Erreur de chargement.</div>';
        }
      }
      
      async function checkAuth() {
        try {
          const res = await fetch('/api/auth.php');
          const contentType = res.headers.get('content-type');
          if (res.ok && contentType && contentType.includes('application/json')) {
            const data = await res.json();
            if (data.ok) {
              root.classList.add('view-admin');
              card.classList.add('wide');
              loadGallery();
            } else {
              root.classList.add('view-login');
              card.classList.remove('wide');
            }
          } else {
            // Probably serving raw PHP file in local dev
            console.warn('Authentication API returned non-JSON. Fallback to login view.');
            root.classList.add('view-login');
            card.classList.remove('wide');
          }
        } catch(e) {
          console.error(e);
          root.classList.add('view-login');
        }
        root.style.opacity = '1';
      }
      checkAuth();

      // LOGIN
      const loginForm = document.getElementById('login-form');
      if (loginForm) {
        loginForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = loginForm.querySelector('button');
          const errorEl = document.getElementById('login-error');
          btn.textContent = 'Connexion...';
          btn.disabled = true;
          try {
            const formData = new FormData(loginForm);
            const res = await fetch('/api/auth.php', { method: 'POST', body: formData });
            const contentType = res.headers.get('content-type');
            if (res.ok && contentType && contentType.includes('application/json')) {
              const data = await res.json();
              if (data.ok) {
                window.location.reload();
              } else {
                throw new Error(data.error || 'Erreur');
              }
            } else {
              throw new Error('Erreur réseau ou code PHP brut');
            }
          } catch (err) {
            errorEl.textContent = err.message;
            errorEl.style.display = 'block';
            btn.textContent = 'ACCÉDER';
            btn.disabled = false;
          }
        });
      }

      // LOGOUT
      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          await fetch('/api/logout.php', { method: 'POST' });
          window.location.reload();
        });
      }

      // DELETE
      document.addEventListener('click', async (e) => {
        const target = e.target;
        if (!target) return;
        const btn = target.closest && target.closest('.delete-btn');
        if (!btn) return;
        const item = btn.closest('.gallery-item');
        if (!item) return;
        const publicId = item.dataset.publicId;
        if (!publicId || !confirm('Supprimer cette photo ?')) return;
        btn.textContent = '…';
        try {
          const fd = new FormData();
          fd.append('public_id', publicId);
          const res = await fetch('/api/delete.php', { method: 'POST', body: fd });
          const contentType = res.headers.get('content-type');
          if (res.ok && contentType && contentType.includes('application/json')) {
            const data = await res.json();
            if (data.ok) {
              item.remove();
            } else {
              throw new Error(data.error);
            }
          } else {
            throw new Error('Erreur API (PHP brut ?)');
          }
        } catch(err) {
          btn.textContent = '✕';
          alert('Erreur lors de la suppression.');
        }
      });

      // UPLOAD
      const uploadForm = document.getElementById('upload-form');
      if (uploadForm) {
        const fileInput = document.getElementById('file-input');
        const dropZone = document.getElementById('drop-zone');
        const editorBox = document.getElementById('editor-box');
        const imageToCrop = document.getElementById('image-to-crop');
        const titleInput = document.getElementById('title-input');
        const categoryInput = document.getElementById('category-input');
        const iaInput = document.getElementById('ia-input');
        const submitBtn = document.getElementById('submit-btn');
        const errorEl = document.getElementById('upload-error');
        const successEl = document.getElementById('upload-success');
        
        let cropper = null;
        let selectedFileName = '';

        function checkForm() {
          submitBtn.disabled = !(cropper && titleInput.value.trim() && categoryInput.value);
        }

        function destroyCropper() {
          if (cropper) {
            cropper.destroy();
            cropper = null;
          }
          editorBox.style.display = 'none';
          dropZone.style.display = 'block';
          fileInput.value = '';
          checkForm();
        }

        function showEditor(file) {
          selectedFileName = file.name;
          const url = URL.createObjectURL(file);
          imageToCrop.src = url;
          dropZone.style.display = 'none';
          editorBox.style.display = 'flex';
          
          if (cropper) { cropper.destroy(); }
          cropper = new Cropper(imageToCrop, {
            viewMode: 1,
            autoCropArea: 1,
            responsive: true,
            rotatable: true
          });
          
          checkForm();
        }

        document.getElementById('btn-rotate-left').addEventListener('click', () => { if (cropper) { cropper.rotate(-90); } });
        document.getElementById('btn-rotate-right').addEventListener('click', () => { if (cropper) { cropper.rotate(90); } });
        document.getElementById('btn-reset').addEventListener('click', () => { if (cropper) { cropper.reset(); } });
        document.getElementById('btn-cancel').addEventListener('click', destroyCropper);

        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', () => {
          if (fileInput.files[0]) showEditor(fileInput.files[0]);
        });
        dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
        dropZone.addEventListener('drop', (e) => {
          e.preventDefault();
          dropZone.classList.remove('drag-over');
          if (e.dataTransfer && e.dataTransfer.files[0]) showEditor(e.dataTransfer.files[0]);
        });

        titleInput.addEventListener('input', checkForm);

        document.getElementById('chips').addEventListener('click', (e) => {
          const target = e.target;
          if (!target || !target.classList.contains('chip')) return;
          document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
          target.classList.add('selected');
          categoryInput.value = target.dataset.value;
          checkForm();
        });

        uploadForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!cropper) return;
          submitBtn.textContent = 'Publication...';
          submitBtn.disabled = true;
          errorEl.style.display = 'none';
          successEl.style.display = 'none';
          
          cropper.getCroppedCanvas({ maxWidth: 2000, maxHeight: 2000 }).toBlob(async (blob) => {
            try {
              const fd = new FormData();
              fd.append('photo', blob, selectedFileName);
              fd.append('title', titleInput.value.trim());
              fd.append('category', categoryInput.value);
              fd.append('is_ia', iaInput.checked ? 'true' : 'false');
              
              const res = await fetch('/api/upload.php', { method: 'POST', body: fd });
              const contentType = res.headers.get('content-type');
              
              if (res.ok && contentType && contentType.includes('application/json')) {
                const data = await res.json();
                if (data.ok) {
                  successEl.style.display = 'block';
                  destroyCropper();
                  titleInput.value = '';
                  categoryInput.value = '';
                  iaInput.checked = false;
                  document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
                  loadGallery();
                } else {
                  throw new Error(data.error || 'Erreur inconnue');
                }
              } else {
                throw new Error('API non valide (PHP non supporté en local?)');
              }
            } catch(err) {
              errorEl.textContent = err.message;
              errorEl.style.display = 'block';
            }
            submitBtn.textContent = 'PUBLIER DANS LA GALERIE →';
            checkForm();
          }, 'image/webp', 0.9);
        });
      }
    </script>
  </body>
</html>
