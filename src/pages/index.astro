---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import ExpertiseSection from "../components/sections/ExpertiseSection.astro";
import RealisationsSection from "../components/sections/RealisationsSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import Footer from "../components/common/Footer.astro";
import { Image } from "astro:assets";
import heroBg from "../assets/home/index-hero-bg.png";
import { fetchGalleryImages } from "../lib/cloudinary";
import { categories } from "../data/realisations";

// Une image de couverture par catégorie pour la section réalisations
let coverImages: Record<string, string> = {};
try {
  const images = await fetchGalleryImages();
  for (const cat of categories.filter(c => c.id !== 'all')) {
    const found = images.find(img => img.category === cat.id);
    if (found) coverImages[cat.id] = found.secure_url;
  }
} catch {}
---

<Layout
    title="KDMS — Fabricant Français de Flight Cases Sur Mesure | Tigery, Paris"
    description="KDMS fabrique vos flight cases sur mesure 100% custom. Île-de-France, Tigery (91250). Audio, événementiel, industrie, meubles. Devis gratuit. 20 ans expertise. Made in France."
>
    <Navbar />

    <div class="main-wrapper bg-black w-full overflow-x-hidden">
        <section
            id="hero-section"
            class="h-screen w-full relative overflow-hidden flex flex-col items-center bg-[#0E0E0E]"
        >
            <Image
                id="hero-bg"
                src={heroBg}
                alt="Atelier de fabrication de flight cases sur mesure KDMS"
                loading="eager"
                fetchpriority="high"
                class="absolute inset-0 w-full h-full object-cover object-center z-0 brightness-[0.5] blur-[3px]"
                decoding="async"
            />
            <div class="absolute inset-0 bg-black/20 z-1 pointer-events-none">
            </div>

            <div
                class="relative z-20 w-full h-full flex flex-col items-center justify-center pt-8 sm:pt-20 lg:pt-24 pb-4 sm:pb-12"
            >
                <div
                    class="hero-text text-center w-full max-w-[95%] md:max-w-[80%] lg:max-w-[70%] mx-auto px-2"
                >
                    <h1
                        class="font-bold text-white tracking-tight text-[clamp(4rem,12vw,8rem)] leading-none"
                    >
                        K-DMS
                    </h1>
                    <p
                        class="mt-2 sm:mt-1 uppercase text-balance tracking-[0.05em] sm:tracking-[0.15em] md:tracking-[0.2em] font-medium px-1 sm:px-4 text-[clamp(1.1rem,3.5vw,2rem)]"
                    >
                        <span class="text-[#B8B8B8]">Le flight case</span>
                        <span class="text-[#4A5D23] font-bold">100% custom</span
                        >
                    </p>
                </div>

                <div class="flight-case-container relative w-full flex justify-center mt-6 sm:mt-8 md:-mt-2 lg:mt-4 mb-2 sm:mb-4 z-30 pointer-events-none px-4 md:px-0">
                    <model-viewer
                        id="flight-case-3d"
                        src="/models/Flight.glb"
                        alt="Flight case sur mesure KDMS — modèle 3D"
                        interaction-prompt="none"
                        shadow-intensity="0.5"
                        environment-image="neutral"
                        exposure="1.2"
                        camera-orbit="0deg 90deg 20%"
                        style="width: min(95vw, 1200px); height: clamp(200px, 45vh, 900px); background: transparent; --poster-color: transparent;"
                    >
                        <div slot="progress-bar"></div>
                    </model-viewer>
                </div>
                <script is:inline>
                    let resizeHandler;

                    document.addEventListener('astro:page-load', () => {
                        const flightCaseModel = document.getElementById('flight-case-3d');
                        if (!flightCaseModel) return;

                        function adjustCamera() {
                            if (window.innerWidth < 768) {
                                flightCaseModel.setAttribute('camera-orbit', '0deg 90deg 110%');
                            } else {
                                flightCaseModel.setAttribute('camera-orbit', '0deg 90deg 20%');
                            }
                        }

                        adjustCamera();
                        if (resizeHandler) window.removeEventListener('resize', resizeHandler);
                        resizeHandler = adjustCamera;
                        window.addEventListener('resize', resizeHandler);
                    });

                    document.addEventListener('astro:before-preparation', () => {
                        if (resizeHandler) window.removeEventListener('resize', resizeHandler);
                    });
                </script>

                <div
                    class="scroll-indicator flex flex-col items-center gap-1 cursor-pointer animate-bounce"
                >
                    <span
                        class="text-[#B8B8B8] text-xs uppercase tracking-[0.2em] font-bold"
                        >Scroll</span
                    >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="text-[#B8B8B8]"
                    >
                        <path d="M7 13l5 5 5-5"></path>
                        <path d="M7 6l5 5 5-5"></path>
                    </svg>
                </div>
            </div>
        </section>
        <div
            id="black-overlay"
            class="absolute inset-0 bg-black opacity-0 z-10 pointer-events-none"
        >
        </div>
    </div>

    <section
        id="content-section"
        class="bg-black text-white min-h-screen relative z-20"
    >
        <ExpertiseSection />
        <RealisationsSection coverImages={coverImages} />
        <ContactSection />
        
        <!-- SEO Content: Hidden for search engines -->
        <div class="hidden" role="region" aria-label="Flight cases keywords">
            <p>KDMS fabrique flight cases sur mesure à Tigery en Île-de-France depuis 2004. Spécialistes en flight case audiovisuel, équipements événementiel, protection industrie et meubles personnalisés. Solutions 100% custom fabriquées en France.</p>
            <p>Nos flight cases protègent vos équipements audio, vidéo, instruments de musique et matériel professionnel. Service de devis gratuit. Livraison France et international.</p>
        </div>
        
        <Footer />
    </section>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { ScrollToPlugin } from "gsap/ScrollToPlugin";

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    const heroSection = document.querySelector("#hero-section");
    const flightCaseContainer = document.querySelector(".flight-case-container");
    const logoBlack = document.querySelector(".logo-black");
    const logoWhite = document.querySelector(".logo-white");
    const navLinks = document.querySelectorAll(".nav-link");
    const heroText = document.querySelector(".hero-text");

    if (heroSection && flightCaseContainer) {
        const navbarBg = document.querySelector(".navbar-bg") as HTMLElement;
        const scrollSpan = document.querySelector(".scroll-indicator span");
        const scrollSvg = document.querySelector(".scroll-indicator svg");
        const heroBg = document.querySelector("#hero-bg");

        const heroTitle = heroText ? heroText.querySelector("h1") : null;
        const heroSubtitle = heroText ? heroText.querySelector("p") : null;

        const timeline = gsap.timeline({
            scrollTrigger: {
                trigger: heroSection,
                start: "top top",
                end: "+=50%",
                pin: true,
                scrub: 0.5,
                snap: {
                    snapTo: (progress) => {
                        return progress > 0.02 ? 1 : 0;
                    },
                    duration: { min: 0.3, max: 1.0 },
                    delay: 0,
                    ease: "power2.inOut",
                },
            },
        });

        if (heroBg) {
            timeline.fromTo(
                heroBg,
                {
                    y: 0,
                    filter: "blur(3px) brightness(0.8)",
                },
                {
                    y: "10%",
                    filter: "blur(8px) brightness(0.5)",
                    ease: "none",
                    duration: 1,
                },
                0,
            );
        }

        if (heroTitle) {
            timeline.fromTo(
                heroTitle,
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                },
                {
                    y: -100,
                    scale: 1.1,
                    opacity: 0,
                    ease: "power2.in",
                    duration: 0.8,
                },
                0,
            );
        }

        if (heroSubtitle) {
            timeline.fromTo(
                heroSubtitle,
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                },
                {
                    y: -400,
                    scale: 1.3,
                    opacity: 0,
                    ease: "power2.in",
                    duration: 0.6,
                },
                0,
            );
        }

        const viewportSize = Math.max(window.innerWidth, window.innerHeight);
        const containerWidth =
            window.innerWidth >= 768
                ? Math.min(window.innerWidth * 0.95, 1200)
                : window.innerWidth * 0.95;
        
        // Calcul du scale exact nécessaire pour que le container remplisse tout l'écran,
        // avec un fort multiplicateur (x30) pour rentrer au coeur de la texture noire.
        // Sur mobile, la caméra est beaucoup plus lointaine (110%), on compense par un zoom drastiquement plus grand.
        const isMobile = window.innerWidth < 768;
        const targetScale = (viewportSize / containerWidth) * (isMobile ? 120 : 30);
        const targetY = isMobile ? "0px" : "0px";
        const transformOrigin = isMobile ? "center 50%" : "center 60%";

        timeline.fromTo(
            flightCaseContainer,
            {
                scale: 1,
                opacity: 1,
                y: 0,
            },
            {
                scale: targetScale,
                y: targetY,
                transformOrigin: transformOrigin,
                ease: "power2.inOut",
                duration: 1,
            },
            0,
        );

        const scrollIndicator = document.querySelector(".scroll-indicator");
        const blackOverlay = document.querySelector("#black-overlay");

        if (scrollIndicator) {
            scrollIndicator.addEventListener("click", () => {
                const contentSection =
                    document.querySelector("#content-section");
                if (contentSection) {
                    gsap.to(window, {
                        duration: 2.5,
                        scrollTo: { y: contentSection, offsetY: 0 },
                        ease: "power2.inOut",
                    });
                }
            });

            timeline.fromTo(
                scrollIndicator,
                {
                    opacity: 1,
                },
                {
                    opacity: 0,
                    duration: 0.05,
                    ease: "power1.out",
                },
                0.99,
            );
        }

        if (blackOverlay) {
            timeline.to(
                blackOverlay,
                {
                    opacity: 1,
                    duration: 0.2,
                    ease: "power2.inOut",
                },
                0.8,
            );
        }

        timeline.to(
            navbarBg,
            {
                autoAlpha: 1,
                duration: 0.5,
                ease: "power2.out",
            },
            0.9,
        );
    }

    // Cleanup GSAP ScrollTriggers on Astro ViewTransitions navigation
    document.addEventListener('astro:before-preparation', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
    });
</script>
