---

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import ExpertiseSection from "../components/sections/ExpertiseSection.astro";
import RealisationsSection from "../components/sections/RealisationsSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import Footer from "../components/common/Footer.astro";
import { Image } from "astro:assets";
import heroBg from "../assets/home/index-hero-bg2.jpeg";
import logo3d from "../assets/common/logo_3d.glb?url";
import { fetchGalleryImages } from "../lib/cloudinary";
import { categories } from "../data/realisations";

// Une image de couverture par catégorie pour la section réalisations
let coverImages: Record<string, string> = {};
try {
  const images = await fetchGalleryImages();
  for (const cat of categories.filter(c => c.id !== 'all')) {
    const found = images.find(img => img.category === cat.id);
    if (found) coverImages[cat.id] = found.secure_url;
  }
} catch {}
---

<Layout
    title="KDMS — Fabricant Français de Flight Cases Sur Mesure | Tigery, Paris"
    description="KDMS fabrique vos flight cases sur mesure 100% custom. Île-de-France, Tigery (91250). Audio, événementiel, industrie, meubles. Devis gratuit. 20 ans expertise. Made in France."
>
    <Navbar />

    <div class="main-wrapper bg-black w-full overflow-x-hidden">
        <section
            id="hero-section"
            class="h-screen w-full relative flex flex-col items-center bg-[#0E0E0E]"
        >
            <Image
                id="hero-bg"
                src={heroBg}
                alt="Atelier de fabrication de flight cases sur mesure KDMS"
                loading="eager"
                fetchpriority="high"
                class="absolute inset-0 w-full h-full object-cover object-center z-0 brightness-[0.8] blur-[3px]"
                decoding="async"
            />
            <div class="absolute inset-0 bg-black/10 z-1 pointer-events-none">
            </div>

            <div
                class="relative z-20 w-full h-full flex flex-col items-center justify-center pt-8 sm:pt-20 lg:pt-24 pb-4 sm:pb-12"
            >
                <div
                    class="hero-text z-50 flex flex-col items-center justify-center text-center w-full max-w-[95%] md:max-w-[80%] lg:max-w-[70%] mx-auto px-2 mt-8 sm:mt-12 md:mt-16 mb-8 sm:mb-12 md:mb-16"
                >
                    <div class="hero-logo-main relative inline-flex items-center justify-center mb-4 lg:mb-6 w-52 h-52 sm:w-64 sm:h-64 md:w-72 md:h-72 lg:w-80 lg:h-80 mx-auto">
                        <model-viewer
                            src={logo3d}
                            class="block w-full h-full"
                            preload
                            camera-orbit="180deg 75deg 105%"
                            camera-controls={false}
                            disable-zoom
                            disable-pan
                            disable-tap
                            interaction-prompt="none"
                            shadow-intensity="0"
                            environment-image="neutral"
                            exposure="1"
                        ></model-viewer>
                    </div>
                    <h1 class="sr-only">K-DMS - Le flight case 100% custom</h1>
                    <div class="hero-subtitle mt-4 sm:mt-6 bg-black/10 backdrop-blur-md rounded-sm pl-7.5 pr-8.5 md:pr-9.5 py-3 shadow-[0_4px_15px_rgba(0,0,0,0.1)] inline-block">
                        <p
                            class="uppercase text-balance tracking-[2px] md:tracking-[4px] font-bold text-[clamp(1.2rem,2.5vw,1.8rem)] drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)]"
                        >
                            <span class="text-white">Le flight case</span>
                            <span class="text-[#4A5D23]">100% custom</span>
                        </p>
                    </div>
                </div>

                <div
                    class="scroll-indicator flex flex-col items-center gap-1 cursor-pointer animate-bounce"
                >
                    <span
                        class="text-[#B8B8B8] text-xs uppercase tracking-[0.2em] font-bold"
                        >Scroll</span
                    >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="text-[#B8B8B8]"
                    >
                        <path d="M7 13l5 5 5-5"></path>
                        <path d="M7 6l5 5 5-5"></path>
                    </svg>
                </div>
            </div>
        </section>
        <div
            id="black-overlay"
            class="absolute inset-0 bg-black opacity-0 z-10 pointer-events-none"
        >
        </div>
    </div>

    <section
        id="content-section"
        class="bg-black text-white min-h-screen relative z-20"
    >
        <ExpertiseSection />
        <RealisationsSection coverImages={coverImages} />
        <ContactSection />
        
        <!-- SEO Content: Hidden for search engines -->
        <div class="hidden" role="region" aria-label="Flight cases keywords">
            <p>KDMS fabrique flight cases sur mesure à Tigery en Île-de-France depuis 2004. Spécialistes en flight case audiovisuel, équipements événementiel, protection industrie et meubles personnalisés. Solutions 100% custom fabriquées en France.</p>
            <p>Nos flight cases protègent vos équipements audio, vidéo, instruments de musique et matériel professionnel. Service de devis gratuit. Livraison France et international.</p>
        </div>
        
        <Footer />
    </section>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { ScrollToPlugin } from "gsap/ScrollToPlugin";

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    const heroSection = document.querySelector("#hero-section");
    const heroText = document.querySelector(".hero-text");
    const heroLogo = document.querySelector(".hero-logo-main");
    const heroModel = heroLogo?.querySelector("model-viewer") as (HTMLElement & {
        getCameraOrbit?: () => { toString: () => string };
        jumpCameraToGoal?: () => void;
        loaded?: boolean;
    }) | null;
    const navLogoDiv = document.querySelector("#nav-logo-container");
    const navLogoWhite = document.querySelector(".logo-white");

    if (heroModel) {
        const startDeterministicSpin = () => {
            const orbit = heroModel.getCameraOrbit?.().toString() || heroModel.getAttribute("camera-orbit") || "0deg 75deg 105%";
            const parts = orbit.trim().split(/\s+/);
            const thetaRaw = parts[0] || "0deg";
            const phiRaw = parts[1] || "75deg";
            const radiusRaw = parts[2] || "105%";

            const thetaMatch = thetaRaw.match(/^(-?\d*\.?\d+)([a-z%]*)$/i);
            const thetaStart = thetaMatch ? Number(thetaMatch[1]) : 0;
            const thetaUnit = thetaMatch?.[2] || "deg";

            const spinState = { theta: thetaStart };
            const turns = 4;
            const targetTheta = 5; // Angle final souhaité pour le logo 
            let thetaEnd = targetTheta + turns * 360;

            // Ensure a forward spin with enough travel before landing on the target angle.
            while (thetaEnd <= thetaStart + 540) {
                thetaEnd += 360;
            }

            gsap.to(spinState, {
                theta: thetaEnd,
                duration: 3.5,
                ease: "power3.out",
                onUpdate: () => {
                    heroModel.setAttribute("camera-orbit", `${spinState.theta.toFixed(3)}${thetaUnit} ${phiRaw} ${radiusRaw}`);
                    heroModel.jumpCameraToGoal?.();
                },
            });
        };

        if (heroModel.loaded) {
            startDeterministicSpin();
        } else {
            heroModel.addEventListener("load", startDeterministicSpin, { once: true });
        }
    }

    if (heroSection) {
        const navbarBg = document.querySelector(".navbar-bg") as HTMLElement;
        const scrollIndicator = document.querySelector(".scroll-indicator");
        const heroBg = document.querySelector("#hero-bg");
        const heroContent = document.querySelector(".hero-subtitle");

        const timeline = gsap.timeline({
            scrollTrigger: {
                trigger: heroSection,
                start: "top top",
                end: "+=80%",
                pin: true,
                scrub: 1, // Scroll plus fluide, suit parfaitement la souris
            },
        });

        // Compute where the hero logo should go
        const moveLogo = () => {
            if (!heroLogo || !navLogoWhite) return;
            const hRect = heroLogo.getBoundingClientRect();
            const nRect = navLogoWhite.getBoundingClientRect();
            
            // GSAP defaults transform origin to center
            const x = (nRect.left + nRect.width / 2) - (hRect.left + hRect.width / 2);
            const y = (nRect.top + nRect.height / 2) - (hRect.top + hRect.height / 2);
            const scale = nRect.width / hRect.width;

            return { x, y, scale };
        };

        if (heroLogo && navLogoWhite) {
            // First we need to make GSAP calculate the values dynamically or statically
            // Since it's pinned, the heroLogo doesn't scroll natively.
            // We just animate its position to the nav.
            
            // Animation simple et robuste sur un seul To() pour éviter les conflits d'écrasement (overwrite) sur le CSS transform
            timeline.to(heroLogo, {
                x: () => moveLogo()?.x || 0,
                y: () => moveLogo()?.y || 0,
                scale: () => moveLogo()?.scale || 1,
                ease: "power2.inOut",
                duration: 1
            }, 0);

            timeline.to(heroLogo, {
                y: () => moveLogo()?.y || 0,
                ease: "power3.inOut",
                duration: 1
            }, 0);
            
            // Fade out the rest of the hero content immediately
            if (heroContent) {
                timeline.to(heroContent, { opacity: 0, scale: 0.8, duration: 0.3, ease: "power2.in" }, 0);
            }

            // At the very end of the animation, hide the hero logo and show the navbar logo
            timeline.to(heroLogo, { autoAlpha: 0, duration: 0.01 }, 0.99);
            timeline.to(navLogoWhite, { autoAlpha: 1, duration: 0.01 }, 0.99);
        }

        if (scrollIndicator) {
            scrollIndicator.addEventListener("click", () => {
                const contentSection = document.querySelector("#content-section");
                if (contentSection) {
                    gsap.to(window, {
                        duration: 1.5,
                        scrollTo: { y: contentSection, offsetY: 0 },
                        ease: "power2.inOut",
                    });
                }
            });

            timeline.to(scrollIndicator, { opacity: 0, duration: 0.1, ease: "power1.out" }, 0);
        }

        timeline.to(navbarBg, { autoAlpha: 1, duration: 0.2, ease: "power2.out" }, 0.8);
    }

    document.addEventListener('astro:before-preparation', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
    });
</script>
