---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
---

<Layout
    title="Plan du site - KDMS"
    description="Plan du site de KDMS - Vue d'ensemble de toutes les pages de notre site."
>
    <Navbar theme="dark" />

    <main class="bg-black text-white min-h-screen pt-24 sm:pt-28 md:pt-32 pb-16 sm:pb-20 md:pb-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-8">
            <div class="mb-16 text-center">
                <span class="text-[#6b755a] font-bold text-sm tracking-widest uppercase block mb-4">
                    Navigation
                </span>
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight">
                    Plan du site
                </h1>
                <p class="text-white/60 mt-6 max-w-2xl mx-auto text-base sm:text-lg">
                    Retrouvez l'ensemble des pages de notre site pour faciliter votre navigation et découvrir notre expertise en conception de flight cases sur mesure.
                </p>
            </div>

            <div class="space-y-6">
                <article class="bg-white/5 rounded-2xl border border-white/10 p-5 sm:p-8 shadow-lg">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12">
                        <!-- Navigation Principale -->
                        <div>
                            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-[#525946] flex items-center justify-center flex-shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                                </div>
                                Navigation principale
                            </h2>
                            <ul class="space-y-6 flex flex-col pl-4 border-l border-white/10 ml-4 border-dashed">
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Accueil</a>
                                    <p class="text-sm text-white/50 mt-1">Présentation de KDMS et de nos services de création sur mesure.</p>
                                </li>
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/expertise" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Notre expertise</a>
                                    <p class="text-sm text-white/50 mt-1">Découvrez notre processus de fabrication, du devis à la conception 3D et l'assemblage français.</p>
                                </li>
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/realisations" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Nos réalisations</a>
                                    <p class="text-sm text-white/50 mt-1 mb-3">Explorez notre galerie de projets par secteur d'activité :</p>
                                    <ul class="space-y-2 pl-4 text-sm text-white/70 relative before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-px before:bg-white/10">
                                        <li class="relative before:content-[''] before:absolute before:-left-4 before:top-2.5 before:w-3 before:h-px before:bg-white/10"><a href="/realisations#audiovisuel" class="hover:text-white transition-colors">Flight cases Audiovisuel</a></li>
                                        <li class="relative before:content-[''] before:absolute before:-left-4 before:top-2.5 before:w-3 before:h-px before:bg-white/10"><a href="/realisations#evenementiel" class="hover:text-white transition-colors">Flight cases Événementiel</a></li>
                                        <li class="relative before:content-[''] before:absolute before:-left-4 before:top-2.5 before:w-3 before:h-px before:bg-white/10"><a href="/realisations#industrie" class="hover:text-white transition-colors">Solutions Protection Industrie</a></li>
                                        <li class="relative before:content-[''] before:absolute before:-left-4 before:top-2.5 before:w-3 before:h-px before:bg-white/10"><a href="/realisations#meubles" class="hover:text-white transition-colors">Meubles sur mesure</a></li>
                                        <li class="relative before:content-[''] before:absolute before:-left-4 before:top-2.5 before:w-3 before:h-px before:bg-white/10"><a href="/realisations#valise-resine" class="hover:text-white transition-colors">Valises en résine & habillage</a></li>
                                    </ul>
                                </li>
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/contact" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Contact</a>
                                    <p class="text-sm text-white/50 mt-1">Contactez notre atelier de Tigery (Essonne).</p>
                                </li>
                            </ul>
                        </div>

                        <!-- Informations Légales -->
                        <div>
                            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-[#525946] flex items-center justify-center flex-shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                                </div>
                                Légal & Informations
                            </h2>
                            <ul class="space-y-6 flex flex-col pl-4 border-l border-white/10 ml-4 border-dashed">
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/mentions-legales" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Mentions légales</a>
                                    <p class="text-sm text-white/50 mt-1">Informations légales concernant l'éditeur du site et l'hébergement.</p>
                                </li>
                                <li class="relative">
                                    <span class="absolute -left-[21px] top-2.5 w-2 h-2 rounded-full bg-[#6b755a]"></span>
                                    <a href="/rgpd" class="text-lg font-medium text-white hover:text-[#6b755a] transition-colors">Politique de confidentialité</a>
                                    <p class="text-sm text-white/50 mt-1">Déclaration détaillant comment nous protégeons et gérons vos données personnelles.</p>
                                </li>
                            </ul>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
