---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import { Image } from "astro:assets";

import { categories, brandLogos } from "../data/realisations";
import { fetchGalleryImages } from "../lib/cloudinary";

let allProjects: { id: number; title: string; category: string; cloudinaryUrl: string }[] = [];
try {
  const images = await fetchGalleryImages();
  allProjects = images.map((img, i) => ({
    id: i + 1,
    title: img.title,
    category: img.category,
    cloudinaryUrl: img.secure_url,
  }));
} catch (e) {
  console.error('Cloudinary fetch failed:', e);
}
---

<Layout
    title="Réalisations flight cases — Audiovisuel, événementiel, industrie "
    description="Galerie réalisations: flight cases audiovisuel, meubles sur mesure, équipements événementiel, protection industrie. 45+ réalisations. Solutions personnalisées."
>
    <Navbar theme="dark" />

    <main class="main-wrapper bg-black min-h-screen text-white pt-20 sm:pt-24 pb-0">
        <header class="px-4 sm:px-6 md:px-12 lg:px-24 mb-8 sm:mb-12 md:mb-16">
            <h1
                class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold mb-4 sm:mb-6 tracking-tight"
            >
                NOS CRÉATIONS
            </h1>
            <p class="text-white/60 text-base sm:text-lg md:text-xl font-light max-w-2xl leading-relaxed">
                Explorez notre galerie de solutions sur-mesure. Chaque flight
                case est une réponse unique à une contrainte spécifique.
            </p>
        </header>

        <nav
            class="sticky top-14 sm:top-16 md:top-20 lg:top-24 z-40 bg-black/80 backdrop-blur-md w-full mb-6 sm:mb-8 py-3 sm:py-4 px-4 sm:px-6 md:px-12 lg:px-24"
            aria-label="Filtres par catégorie"
        >
            <div class="md:hidden relative">
                <button
                    id="filter-dropdown-btn"
                    type="button"
                    class="w-full flex items-center justify-between bg-white/10 text-white border border-white/20 rounded-lg px-4 py-2.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-white/30"
                >
                    <span id="selected-filter-label">Tout voir</span>
                    <svg class="w-4 h-4 ml-2 transition-transform duration-300" id="dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
                
                <div
                    id="filter-dropdown-menu"
                    class="absolute top-full left-0 right-0 mt-2 bg-black/95 backdrop-blur-md border border-white/20 rounded-lg overflow-hidden shadow-2xl hidden z-50"
                >
                    {
                        categories.map((cat) => (
                            <button
                                type="button"
                                class={`dropdown-item w-full text-left px-4 py-3 text-sm font-medium transition-colors duration-150 active:bg-[#4A5D23]/50 border-b border-white/5 last:border-0 ${cat.id === "all" ? "bg-[#4A5D23] text-white" : "text-white/70"}`}
                                data-category={cat.id}
                            >
                                {cat.label}
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="hidden md:flex flex-wrap justify-start gap-2 lg:gap-3" role="group">
                {
                    categories.map((cat) => (
                        <button
                            type="button"
                            class={`filter-btn px-6 lg:px-8 py-2 lg:py-2.5 rounded-full text-sm lg:text-base font-medium transition-all duration-200 
                                hover:scale-105 whitespace-nowrap will-change-transform ${cat.id === "all" ? "bg-[#4A5D23] text-white" : "bg-transparent text-white/70 hover:bg-white/10 hover:text-white"}`}
                            data-category={cat.id}
                            aria-pressed={cat.id === "all" ? "true" : "false"}
                        >
                            {cat.label}
                        </button>
                    ))
                }
            </div>
        </nav>

        <section
            class="px-4 sm:px-6 md:px-10 lg:px-16 pb-20 sm:pb-32 mx-auto max-w-[1920px]"
            aria-label="Galerie de projets"
        >
            <div
                id="masonry-grid"
                class="columns-2 md:columns-3 xl:columns-4 gap-4 sm:gap-6 lg:gap-8 space-y-4 sm:space-y-6 lg:space-y-8"
            >
                {
                    allProjects.map((project, index) => (
                        <article
                            class="project-item break-inside-avoid relative group cursor-pointer overflow-hidden rounded-xl bg-[#1A1A1A] transition-all duration-700 ease-in-out opacity-0 translate-y-8"
                            data-category={project.category}
                        >
                            <div class="relative w-full overflow-hidden">
                                <img
                                    src={project.cloudinaryUrl}
                                    alt={`Réalisation ${project.title}`}
                                    class="w-full h-auto object-cover transition-all duration-1000 group-hover:scale-105"
                                    loading={index < 4 ? "eager" : "lazy"}
                                    decoding="async"
                                />
                                

                            </div>

                            <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-40 group-hover:opacity-60 transition-opacity duration-500" />

                            <div class="absolute bottom-0 left-0 w-full p-2 sm:p-6 translate-y-2 group-hover:translate-y-0 transition-transform duration-500 ease-out will-change-transform z-10">
                                <div class="bg-black/30 backdrop-blur-xl border border-white/10 rounded-lg sm:rounded-xl p-2 sm:p-4 transform transition-all duration-500 group-hover:bg-black/40 shadow-2xl">
                                    <span class="text-[#E07A1F] text-[9px] sm:text-[10px] font-bold uppercase tracking-widest mb-0.5 sm:mb-1 block opacity-70">
                                        {project.category.replace('-', ' ')}
                                    </span>
                                    <h2 class="text-sm sm:text-lg font-bold text-white mb-0.5 sm:mb-1 leading-tight">
                                        {project.title}
                                    </h2>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>

        <section
            class="w-full py-12 sm:py-16 md:py-24 bg-black border-t border-white/10 overflow-hidden"
            aria-label="Marques partenaires"
        >
            <div class="px-4 sm:px-6 md:px-12 lg:px-24 mb-8 sm:mb-10 text-center">
                <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-white">
                    On vient nous voir pour flighter
                </h2>
            </div>

            <div class="marquee-container relative overflow-hidden">
                <div class="marquee-track flex items-center gap-8 sm:gap-10 md:gap-12 animate-marquee">
                    {
                        brandLogos.map((logo) => (
                            <div class="flex-shrink-0 w-16 sm:w-20 md:w-24 h-8 sm:h-10 md:h-12 flex items-center justify-center">
                                <Image
                                    src={logo.logo}
                                    alt={logo.name}
                                    class="max-w-full max-h-full object-contain opacity-70 hover:opacity-100 transition-opacity duration-300"
                                    style="filter: none !important;"
                                    loading="lazy"
                                />
                            </div>
                        ))
                    }
                    {
                        brandLogos.map((logo) => (
                            <div class="flex-shrink-0 w-16 sm:w-20 md:w-24 h-8 sm:h-10 md:h-12 flex items-center justify-center">
                                <Image
                                    src={logo.logo}
                                    alt={logo.name}
                                    class="max-w-full max-h-full object-contain opacity-70 hover:opacity-100 transition-opacity duration-300"
                                    style="filter: none !important;"
                                    loading="lazy"
                                />
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <footer
            id="footer-section"
            class="bg-black relative z-50 border-t border-white/10"
        >
            <!-- SEO Content: Hidden for search engines -->
            <section class="hidden" role="region" aria-label="Réalisations keywords">
                <p>Réalisations de flight cases audiovisuel: enceintes, amplis, écrans. Flight cases événementiel: son, lumière, équipements scène. Flight cases industrie: protection matériel sensible, transport sécurisé. Meubles sur mesure avec rangements intégrés. Valises résine transportables.</p>
            </section>
            
            <ContactSection />
            <Footer />
        </footer>
        <!-- Modal Photo -->
        <div
            id="image-modal"
            class="fixed inset-0 z-[100] hidden flex-col items-center justify-center bg-black/95 backdrop-blur-md opacity-0 transition-opacity duration-300"
            aria-hidden="true"
            role="dialog"
        >
            <button
                id="close-modal-btn"
                class="absolute top-4 right-4 sm:top-6 sm:right-6 text-white/70 hover:text-white transition-colors p-2 z-10"
                aria-label="Fermer la modale"
            >
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="w-8 h-8 sm:w-10 sm:h-10">
                    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <div class="relative w-full h-full flex flex-col items-center justify-center p-4 sm:p-8 modal-backdrop cursor-pointer">
                <img
                    id="modal-image"
                    src=""
                    alt="Image en plein écran"
                    class="max-w-full max-h-[85vh] object-contain rounded-md shadow-2xl scale-95 transition-transform duration-300 cursor-default"
                    loading="lazy"
                />
                <p id="modal-caption" class="text-white text-lg sm:text-xl font-medium mt-4 text-center cursor-default"></p>
            </div>
        </div>
    </main>
</Layout>

<script>
    const filterBtnsContainer = document.querySelector('[role="group"]');
    const dropdownMenuEl = document.getElementById("filter-dropdown-menu");
    const dropdownBtnEl = document.getElementById("filter-dropdown-btn");
    const dropdownArrowEl = document.getElementById("dropdown-arrow");
    const selectedLabelEl = document.getElementById("selected-filter-label");
    const projectItems = Array.from(document.querySelectorAll<HTMLElement>(".project-item"));
    const masonryGrid = document.getElementById("masonry-grid");
    
    // Elements de la modale
    const imageModal = document.getElementById("image-modal");
    const modalImage = document.getElementById("modal-image") as HTMLImageElement;
    const modalCaption = document.getElementById("modal-caption");
    const closeModalBtn = document.getElementById("close-modal-btn");
    
    const activeClasses = ["bg-[#4A5D23]", "text-white"];
    const inactiveClasses = ["bg-transparent", "text-white/70"];
    const dropdownActiveClasses = ["bg-[#4A5D23]", "text-white"];
    const dropdownInactiveClasses = ["text-white/70"];

    function getCategoryFromURL(): string {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('category') || 'all';
    }

    function getLabelForCategory(category: string): string {
        const btn = filterBtnsContainer?.querySelector<HTMLButtonElement>(`[data-category="${category}"]`);
        return btn?.textContent?.trim() || 'Tout voir';
    }

    let currentCategory = 'all';

    function buildMasonryColumns(category: string, animate = true): void {
        if (!masonryGrid) return;
        currentCategory = category;
        
        const numCols = window.innerWidth >= 1280 ? 4 : window.innerWidth >= 768 ? 3 : 2;
        const visibleItems = projectItems.filter(item => category === 'all' || item.dataset.category === category);
        
        // Reset container to grid layout
        masonryGrid.className = `grid gap-4 sm:gap-6 lg:gap-8 items-stretch pt-2 pb-4 ${
            numCols === 4 ? 'grid-cols-4' : numCols === 3 ? 'grid-cols-3' : 'grid-cols-1 sm:grid-cols-2'
        }`;
        
        masonryGrid.innerHTML = '';
        
        const columns = Array.from({ length: numCols }, () => {
            const col = document.createElement('div');
            col.className = 'flex flex-col gap-4 sm:gap-6 lg:gap-8 min-h-full';
            return col;
        });
        
        // Setup initially
        visibleItems.forEach((item, index) => {
            item.classList.remove("hidden-item", "flex-grow", "flex", "flex-col");
            if (animate) {
                item.classList.add("opacity-0", "translate-y-8");
            } else {
                item.classList.remove("opacity-0", "translate-y-8");
            }
            
            const imgContainer = item.querySelector('.relative.w-full');
            if (imgContainer) {
                imgContainer.classList.remove("h-full", "flex-grow");
                const img = imgContainer.querySelector('img');
                if (img) img.classList.remove("h-full", "object-cover");
            }
            
            columns[index % numCols].appendChild(item);
        });
        
        columns.forEach(col => {
            const lastItem = col.lastElementChild;
            if (lastItem) {
                lastItem.classList.add("flex-grow", "flex", "flex-col");
                const imgContainer = lastItem.querySelector('.relative.w-full');
                if (imgContainer) {
                    imgContainer.classList.add("h-full", "flex-grow");
                    const img = imgContainer.querySelector('img');
                    if (img) img.classList.add("h-full", "object-cover");
                }
            }
            masonryGrid.appendChild(col);
        });
        
        if (animate) {
            visibleItems.forEach((item, index) => {
                setTimeout(() => {
                    item.classList.remove("hidden-item", "opacity-0", "translate-y-8");
                }, index * 30 + 10);
            });
        }
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
            buildMasonryColumns(currentCategory, false);
        }, 150);
    });

    function filterProjects(category: string): void {
        const disappearingItems = projectItems.filter(item => 
            !item.classList.contains("hidden-item") && 
            category !== "all" && item.dataset.category !== category
        );
        
        if (disappearingItems.length > 0) {
            disappearingItems.forEach(item => {
                item.classList.add("opacity-0", "translate-y-8");
            });
            setTimeout(() => {
                buildMasonryColumns(category, true);
            }, 300);
        } else {
            buildMasonryColumns(category, true);
        }
    }
    function updateButtonStates(activeCategory: string): void {
        const btns = filterBtnsContainer?.querySelectorAll<HTMLButtonElement>(".filter-btn");
        btns?.forEach((b) => {
            const isActive = b.dataset.category === activeCategory;
            b.classList.remove(...(isActive ? inactiveClasses : activeClasses));
            b.classList.add(...(isActive ? activeClasses : inactiveClasses));
            b.setAttribute("aria-pressed", String(isActive));
        });
    }

    function updateDropdownStates(activeCategory: string, label: string): void {
        if (selectedLabelEl) selectedLabelEl.textContent = label;
        
        dropdownMenuEl?.querySelectorAll<HTMLButtonElement>(".dropdown-item").forEach((i) => {
            const isActive = i.dataset.category === activeCategory;
            i.classList.remove(...(isActive ? dropdownInactiveClasses : dropdownActiveClasses));
            i.classList.add(...(isActive ? dropdownActiveClasses : dropdownInactiveClasses));
        });
    }

    function toggleDropdown(): void {
        const isHidden = dropdownMenuEl?.classList.toggle("hidden");
        dropdownArrowEl?.classList.toggle("rotate-180", !isHidden);
    }

    function closeDropdown(): void {
        dropdownMenuEl?.classList.add("hidden");
        dropdownArrowEl?.classList.remove("rotate-180");
    }

    function handleFilterSelect(category: string, label: string): void {
        filterProjects(category);
        updateButtonStates(category);
        updateDropdownStates(category, label);
    }
    dropdownBtnEl?.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleDropdown();
    });
    dropdownMenuEl?.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest<HTMLButtonElement>(".dropdown-item");
        if (!target) return;
        
        const category = target.dataset.category || "all";
        const label = target.textContent?.trim() || "Tout voir";
        handleFilterSelect(category, label);
        closeDropdown();
    });

    filterBtnsContainer?.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-btn");
        if (!target) return;
        
        const category = target.dataset.category || "all";
        const label = target.textContent?.trim() || "Tout voir";
        handleFilterSelect(category, label);
    });

    document.addEventListener("click", (e) => {
        const target = e.target as Node;
        if (!dropdownBtnEl?.contains(target) && !dropdownMenuEl?.contains(target)) {
            closeDropdown();
        }
    }, { passive: true });

    // Fonctions de la modale
    function openModal(imgSrc: string, title: string) {
        if (!imageModal || !modalImage) return;
        modalImage.src = imgSrc;
        if (modalCaption) modalCaption.textContent = title;
        
        imageModal.classList.remove("hidden");
        // Forcer le recalcul du layout pour la transition CSS
        void imageModal.offsetWidth;
        
        imageModal.classList.add("flex");
        imageModal.classList.remove("opacity-0");
        modalImage.classList.remove("scale-95");
        modalImage.classList.add("scale-100");
        document.body.style.overflow = "hidden"; // Empêche le défilement de la page
    }

    function closeModal() {
        if (!imageModal || !modalImage) return;
        imageModal.classList.add("opacity-0");
        modalImage.classList.remove("scale-100");
        modalImage.classList.add("scale-95");
        document.body.style.overflow = "";

        setTimeout(() => {
            imageModal.classList.add("hidden");
            imageModal.classList.remove("flex");
            modalImage.src = "";
        }, 300);
    }

    projectItems.forEach((item) => {
        item.addEventListener("click", () => {
            const imgEl = item.querySelector("img");
            const titleEl = item.querySelector("h2");
            if (imgEl && imgEl.src) {
                const title = titleEl ? titleEl.textContent : "";
                openModal(imgEl.src, title || "");
            }
        });
    });

    closeModalBtn?.addEventListener("click", closeModal);
    imageModal?.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target === imageModal || target.classList.contains('modal-backdrop')) {
            closeModal();
        }
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !imageModal?.classList.contains("hidden")) {
            closeModal();
        }
    });

    document.addEventListener('DOMContentLoaded', () => {
        const initialCategory = getCategoryFromURL();
        const initialLabel = getLabelForCategory(initialCategory);
        buildMasonryColumns(initialCategory, false); // Initialize layout
        updateButtonStates(initialCategory);
        updateDropdownStates(initialCategory, initialLabel);
    });
</script>

<style>
    .hidden-item {
        display: none;
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .marquee-track {
        width: max-content;
    }

    .animate-marquee {
        animation: marquee 25s linear infinite;
        will-change: transform;
    }

    @media (max-width: 768px) {
        .animate-marquee {
            animation-duration: 15s;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .animate-marquee {
            animation: none;
        }
        
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }

    @media (hover: none) and (pointer: coarse) {
        .group:hover .group-hover\:scale-105 {
            transform: none;
        }
    

        
        .filter-btn:hover {
            transform: none !important;
        }
    }
</style>
