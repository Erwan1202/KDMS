{
  "build": {
    "env": {
      "VERCEL_ANALYZE_BUILD_OUTPUT": "1"
    }
  },
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2",
      "excludeFiles": [
        "src/**",
        "dist/**",
        "node_modules/**",
        "public/**",
        ".git/**",
        ".worktrees/**",
        ".vercel/**",
        ".astro/**",
        "*.md",
        "package*.json",
        "tsconfig.json",
        "astro.config.mjs",
        "vitest.config.ts"
      ]
    }
  }
}