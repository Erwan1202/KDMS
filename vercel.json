{
  "build": {
    "env": {
      "VERCEL_ANALYZE_BUILD_OUTPUT": "1"
    }
  },
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2",
      "excludeFiles": "{src/**,node_modules/**,public/**,.git/**,.worktrees/**,.vercel/**,.astro/**,dist/**,*.md,package*.json,tsconfig.json}"
    }
  }
}
